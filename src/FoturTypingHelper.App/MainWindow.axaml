<Window xmlns="https://github.com/avaloniaui" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 x:Class="FoturTypingHelper.App.MainWindow" Width="1180" Height="790" MinWidth="980" MinHeight="680"
 WindowStartupLocation="CenterScreen" Title="Fotur Typing Helper">
 <Grid ColumnDefinitions="252,*">
  <Border Background="#090D0F" BorderBrush="#1C262A" BorderThickness="0,0,1,0" Padding="22,24">
   <Grid RowDefinitions="Auto,Auto,*,Auto">
    <StackPanel Orientation="Horizontal" Spacing="12">
     <Border Width="42" Height="42" CornerRadius="13" Background="#62FFF7" BoxShadow="0 6 24 0 #3262FFF7"><TextBlock Text="FT" Foreground="#041214" FontWeight="Black" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
     <StackPanel VerticalAlignment="Center"><TextBlock Text="FOTUR" FontWeight="Black" FontSize="17" LetterSpacing="2.4"/><TextBlock Text="typing helper" Classes="muted" FontSize="11"/></StackPanel>
    </StackPanel>
    <Border Grid.Row="1" Margin="0,28,0,22" Classes="card" Padding="15">
     <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto"><Border Width="9" Height="9" CornerRadius="5" Background="#52E58A" BoxShadow="0 0 12 0 #8052E58A"/><TextBlock Grid.Column="1" Text="Система активна" Margin="10,-2,0,0" FontWeight="SemiBold"/><TextBlock Grid.Row="1" Grid.ColumnSpan="2" x:Name="StatusText" Text="Локальная защита включена" Classes="muted" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/></Grid>
    </Border>
    <StackPanel Grid.Row="2" Spacing="4">
     <Button x:Name="NavDashboard" Classes="nav active" Content="⌂   Обзор" Click="ShowDashboard"/>
     <Button x:Name="NavCorrection" Classes="nav" Content="⌨   Автокоррекция" Click="ShowCorrection"/>
     <Button x:Name="NavDictation" Classes="nav" Content="●   Диктовка" Click="ShowDictation"/>
     <Button x:Name="NavDictionary" Classes="nav" Content="◇   Личный словарь" Click="ShowDictionary"/>
     <Button x:Name="NavSettings" Classes="nav" Content="⚙   Настройки" Click="ShowSettings"/>
     <Button x:Name="NavAbout" Classes="nav" Content="▥   О программе" Click="ShowAbout"/>
    </StackPanel>
    <Border Grid.Row="3" Classes="setting" Padding="14">
     <StackPanel Spacing="8"><Grid ColumnDefinitions="*,Auto"><TextBlock Text="ДИКТОВКА" Classes="eyebrow"/><Border Grid.Column="1" Classes="badge"><TextBlock Text="LOCAL" Foreground="#52E58A" FontSize="9" FontWeight="Bold"/></Border></Grid><TextBlock x:Name="SidebarHotkeyText" Text="Ctrl + Alt + Space" FontFamily="Cascadia Mono, Consolas" FontSize="12"/><TextBlock Text="Удерживайте или нажмите — зависит от выбранного режима" Classes="muted" FontSize="10" TextWrapping="Wrap"/></StackPanel>
    </Border>
   </Grid>
  </Border>

  <Grid Grid.Column="1" Background="#06080A">
   <Canvas IsHitTestVisible="False" Opacity="0.18"><Ellipse Width="520" Height="520" Fill="#123B3E" Canvas.Left="-120" Canvas.Top="-330"/><Ellipse Width="450" Height="450" Fill="#3B1233" Canvas.Right="-170" Canvas.Bottom="-290"/></Canvas>
   <ScrollViewer><Grid Margin="42,34,42,48">
    <StackPanel x:Name="DashboardPanel" Spacing="22">
     <Grid ColumnDefinitions="*,Auto"><StackPanel Spacing="8"><TextBlock Text="SYSTEM / OVERVIEW" Classes="eyebrow"/><TextBlock Text="Печатайте. Говорите. Не переключайтесь." Classes="h1"/><TextBlock Text="Два незаметных помощника работают в фоне и не отправляют ваш текст в интернет." Classes="muted" FontSize="14"/></StackPanel><Border Grid.Column="1" Classes="badge" VerticalAlignment="Top"><StackPanel Orientation="Horizontal" Spacing="7"><Border Width="7" Height="7" CornerRadius="4" Background="#52E58A"/><TextBlock Text="ВСЁ РАБОТАЕТ ЛОКАЛЬНО" FontSize="9" FontWeight="Bold" Foreground="#A9BBB9"/></StackPanel></Border></Grid>
     <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
      <Border Classes="card"><Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="Автокоррекция" FontSize="18" FontWeight="Bold"/><TextBlock Text="Исправляет неверную раскладку вместе с предыдущими словами" Classes="muted" FontSize="12" Margin="0,5,0,0"/></StackPanel><ToggleSwitch Grid.Column="1" x:Name="AutoCorrectionToggle" Checked="SettingChanged" Unchecked="SettingChanged"/><Border Grid.Row="1" Grid.ColumnSpan="2" Classes="setting" Margin="0,20,0,12"><Grid ColumnDefinitions="*,Auto"><TextBlock Text="ghbdtn rfr ltkf" FontFamily="Cascadia Mono, Consolas" Foreground="#839096" FontSize="17"/><TextBlock Grid.Column="1" Text="→  привет как дела" FontFamily="Cascadia Mono, Consolas" Foreground="#62FFF7" FontSize="17"/></Grid></Border><TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="Исправление после пробела · отмена за 8 секунд" Classes="muted" FontSize="11"/><Button Grid.Row="3" Grid.ColumnSpan="2" Classes="secondary" Content="Настроить автокоррекцию" Click="ShowCorrection" HorizontalAlignment="Left" Margin="0,17,0,0"/></Grid></Border>
      <Border Grid.Column="1" Classes="card"><Grid RowDefinitions="Auto,Auto,Auto,Auto" ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="Голосовая диктовка" FontSize="18" FontWeight="Bold"/><TextBlock Text="Русский, английский, пунктуация и голосовые команды" Classes="muted" FontSize="12" Margin="0,5,0,0"/></StackPanel><ToggleSwitch Grid.Column="1" x:Name="DictationToggle" Checked="SettingChanged" Unchecked="SettingChanged"/><Border Grid.Row="1" Grid.ColumnSpan="2" Classes="setting" Margin="0,20,0,12"><Grid ColumnDefinitions="Auto,*,Auto"><Border Width="36" Height="36" CornerRadius="18" Background="#FF5BDD"><TextBlock Text="●" Foreground="#24051D" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><StackPanel Grid.Column="1" Margin="12,0"><TextBlock Text="RU  ↔  EN" Foreground="#FF78E5" FontWeight="Bold"/><TextBlock x:Name="ModelStatusText" Text="Whisper base" Classes="muted" FontSize="11"/></StackPanel><TextBlock Grid.Column="2" Text="OFFLINE" Foreground="#52E58A" FontSize="10" FontWeight="Bold" VerticalAlignment="Center"/></Grid></Border><TextBlock Grid.Row="2" Grid.ColumnSpan="2" Text="Первый запуск загрузит выбранную модель" Classes="muted" FontSize="11"/><Button Grid.Row="3" Grid.ColumnSpan="2" Classes="primary" Content="Проверить микрофон" Click="ToggleDictation" HorizontalAlignment="Left" Margin="0,17,0,0"/></Grid></Border>
     </Grid>
     <TextBlock Text="ВАШ РЕЗУЛЬТАТ" Classes="eyebrow" Margin="0,5,0,-8"/>
     <Grid ColumnDefinitions="*,*,*" ColumnSpacing="12"><Border Classes="card" Padding="19"><StackPanel Spacing="4"><TextBlock x:Name="CorrectionsStat" Text="0" FontSize="29" FontWeight="Bold"/><TextBlock Text="исправлений раскладки" Classes="muted" FontSize="11"/></StackPanel></Border><Border Grid.Column="1" Classes="card" Padding="19"><StackPanel Spacing="4"><TextBlock x:Name="DictatedStat" Text="0" FontSize="29" FontWeight="Bold"/><TextBlock Text="слов продиктовано" Classes="muted" FontSize="11"/></StackPanel></Border><Border Grid.Column="2" Classes="card" Padding="19"><StackPanel Spacing="4"><TextBlock x:Name="SavedStat" Text="0" FontSize="29" FontWeight="Bold"/><TextBlock Text="нажатий сэкономлено" Classes="muted" FontSize="11"/></StackPanel></Border></Grid>
    </StackPanel>

    <StackPanel x:Name="CorrectionPanel" IsVisible="False" Spacing="20">
     <TextBlock Text="INPUT / AUTOCORRECTION" Classes="eyebrow"/><TextBlock Text="Автокоррекция раскладки" Classes="h1"/><TextBlock Text="Fotur анализирует последние слова и исправляет всю ошибочно набранную фразу сразу после пробела." Classes="muted" FontSize="14"/>
     <Border Classes="card"><StackPanel Spacing="12">
      <Border Classes="setting"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="Автоматическое исправление" FontWeight="SemiBold"/><TextBlock Text="Определяет русский текст в английской раскладке и наоборот" Classes="muted" FontSize="11" Margin="0,4,0,0"/></StackPanel><ToggleSwitch Grid.Column="1" x:Name="CorrectionEnabledSettings" Checked="SettingChanged" Unchecked="SettingChanged"/></Grid></Border>
      <Border Classes="setting"><Grid ColumnDefinitions="*,Auto,Auto"><StackPanel><StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="Раннее исправление" FontWeight="SemiBold"/><Border Classes="badge"><TextBlock Text="ЭКСПЕРИМЕНТ" Foreground="#FF82E7" FontSize="9" FontWeight="Bold"/></Border></StackPanel><TextBlock Text="Пытается исправить слово до пробела только при очень высокой уверенности" Classes="muted" FontSize="11" Margin="0,4,0,0"/></StackPanel><Button Grid.Column="1" Classes="info" Content="i" Margin="0,0,12,0" ToolTip.Tip="Экспериментальный режим реагирует быстрее, но на редких именах и сокращениях может ошибаться. Обычный режим надёжнее: он ждёт пробел и видит контекст фразы."/><CheckBox Grid.Column="2" x:Name="EarlyCorrectionCheck" Click="SettingChanged" VerticalAlignment="Center"/></Grid></Border>
      <Border Classes="setting"><Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto"><StackPanel Orientation="Horizontal" Spacing="8"><TextBlock Text="Порог уверенности" FontWeight="SemiBold"/><Button Classes="info" Content="i" ToolTip.Tip="Чем выше значение, тем реже Fotur вмешивается. 72% — сбалансированный режим; 85% и выше полезны для кода и профессиональных терминов."/></StackPanel><TextBlock Grid.Column="1" x:Name="ConfidenceValueText" Text="72%" Foreground="#62FFF7" FontWeight="Bold"/><Slider Grid.Row="1" Grid.ColumnSpan="2" x:Name="ConfidenceSlider" Minimum="0.55" Maximum="0.95" ValueChanged="SettingChanged" Margin="0,12,0,0"/></Grid></Border>
      <Border Classes="setting"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="Мгновенная отмена" FontWeight="SemiBold"/><TextBlock x:Name="UndoHotkeySummary" Text="Ctrl + Alt + Backspace · доступна 8 секунд" Classes="muted" FontSize="11" Margin="0,4,0,0"/></StackPanel><Button Grid.Column="1" Classes="secondary" Content="Изменить" Click="ShowSettings"/></Grid></Border>
     </StackPanel></Border>
    </StackPanel>

    <StackPanel x:Name="DictationPanel" IsVisible="False" Spacing="20">
     <TextBlock Text="VOICE / LOCAL AI" Classes="eyebrow"/><TextBlock Text="Голосовая диктовка" Classes="h1"/><TextBlock Text="Запишите фразу — локальный Whisper расставит пунктуацию и вставит результат в активное поле." Classes="muted" FontSize="14"/>
     <Border Classes="card"><StackPanel Spacing="12">
      <Border Classes="setting"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="Глобальная диктовка" FontWeight="SemiBold"/><TextBlock Text="Работает поверх браузера, мессенджеров и редакторов" Classes="muted" FontSize="11" Margin="0,4,0,0"/></StackPanel><ToggleSwitch Grid.Column="1" x:Name="DictationEnabledSettings" Checked="SettingChanged" Unchecked="SettingChanged"/></Grid></Border>
      <Border Classes="setting"><Grid ColumnDefinitions="*,260,Auto"><StackPanel><TextBlock Text="Поведение горячей клавиши" FontWeight="SemiBold"/><TextBlock Text="Удерживать или переключать запись одним нажатием" Classes="muted" FontSize="11" Margin="0,4,0,0"/></StackPanel><ComboBox Grid.Column="1" x:Name="HotkeyModeCombo" SelectionChanged="SettingChanged"><ComboBoxItem Content="Удерживать, пока говорю"/><ComboBoxItem Content="Нажать для старта и остановки"/></ComboBox><Button Grid.Column="2" Classes="info" Content="i" Margin="10,0,0,0" ToolTip.Tip="Режим удержания удобен для коротких фраз. Режим переключателя лучше подходит для длинной диктовки и освобождает руки."/></Grid></Border>
      <Border Classes="setting"><Grid ColumnDefinitions="*,260,Auto"><StackPanel><TextBlock Text="Модель распознавания" FontWeight="SemiBold"/><TextBlock Text="Большая модель точнее, но требует больше памяти и времени" Classes="muted" FontSize="11" Margin="0,4,0,0"/></StackPanel><ComboBox Grid.Column="1" x:Name="ModelCombo" SelectionChanged="SettingChanged"><ComboBoxItem Content="Tiny — максимальная скорость"/><ComboBoxItem Content="Base — баланс"/><ComboBoxItem Content="Small — высокая точность"/><ComboBoxItem Content="Medium — максимум качества"/></ComboBox><Button Grid.Column="2" Classes="info" Content="i" Margin="10,0,0,0" ToolTip.Tip="Tiny подходит слабым ПК. Base рекомендуется по умолчанию. Small и Medium лучше понимают сленг и смешанную речь, но загружаются дольше."/></Grid></Border>
      <Border Classes="setting"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="Голосовые команды" FontWeight="SemiBold"/><TextBlock Text="«новая строка», «точка», «запятая», «вопросительный знак»" Classes="muted" FontSize="11" Margin="0,4,0,0"/></StackPanel><CheckBox Grid.Column="1" x:Name="VoiceCommandsCheck" Click="SettingChanged"/></Grid></Border>
      <Button Classes="primary" Content="Начать тестовую диктовку" Click="ToggleDictation" HorizontalAlignment="Left" Margin="0,8,0,0"/>
     </StackPanel></Border>
    </StackPanel>

    <StackPanel x:Name="DictionaryPanel" IsVisible="False" Spacing="20">
     <TextBlock Text="LANGUAGE / DICTIONARY" Classes="eyebrow"/><TextBlock Text="Личный словарь" Classes="h1"/><TextBlock Text="Добавляйте имена, бренды, сленг и рабочие термины — Fotur перестанет считать их ошибками." Classes="muted" FontSize="14"/>
     <Border Classes="card"><StackPanel Spacing="15"><Grid ColumnDefinitions="*,Auto" ColumnSpacing="10"><TextBox x:Name="DictionaryInput" Watermark="Например: Fotur, Avalonia, промптинг"/><Button Grid.Column="1" Classes="primary" Content="Добавить слово" Click="AddDictionaryWord"/></Grid><Border Classes="setting"><ListBox x:Name="DictionaryList" MinHeight="270" Background="Transparent" BorderThickness="0"/></Border><TextBlock Text="Словарь хранится только на этом компьютере." Classes="muted" FontSize="11"/></StackPanel></Border>
    </StackPanel>

    <StackPanel x:Name="SettingsPanel" IsVisible="False" Spacing="20">
     <TextBlock Text="APP / SETTINGS" Classes="eyebrow"/><TextBlock Text="Настройки" Classes="h1"/><TextBlock Text="Управляйте поведением приложения, сочетаниями клавиш и приватностью." Classes="muted" FontSize="14"/>
     <Grid ColumnDefinitions="*,*" ColumnSpacing="16">
      <Border Classes="card"><StackPanel Spacing="12"><TextBlock Text="Приложение" FontSize="17" FontWeight="Bold" Margin="0,0,0,4"/><Border Classes="setting"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="Запускать вместе с Windows" FontWeight="SemiBold"/><TextBlock Text="Fotur будет готов сразу после входа" Classes="muted" FontSize="11"/></StackPanel><ToggleSwitch Grid.Column="1" x:Name="AutostartToggle" Checked="SettingChanged" Unchecked="SettingChanged"/></Grid></Border><Border Classes="setting"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="Закрывать в трей" FontWeight="SemiBold"/><TextBlock Text="Крестик скрывает окно, но не останавливает помощника" Classes="muted" FontSize="11"/></StackPanel><ToggleSwitch Grid.Column="1" x:Name="TrayToggle" Checked="SettingChanged" Unchecked="SettingChanged"/></Grid></Border><Border Classes="setting"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="Локальная статистика" FontWeight="SemiBold"/><TextBlock Text="Только числа — содержимое текста не сохраняется" Classes="muted" FontSize="11"/></StackPanel><ToggleSwitch Grid.Column="1" x:Name="StatisticsToggle" Checked="SettingChanged" Unchecked="SettingChanged"/></Grid></Border><Button Classes="secondary" Content="Очистить статистику" Click="ClearStatistics" HorizontalAlignment="Left"/></StackPanel></Border>
      <Border Grid.Column="1" Classes="card"><StackPanel Spacing="12"><Grid ColumnDefinitions="*,Auto"><TextBlock Text="Горячие клавиши" FontSize="17" FontWeight="Bold"/><Button Grid.Column="1" Classes="info" Content="i" ToolTip.Tip="Нажмите в поле и введите новое сочетание целиком. Fotur проверит конфликт между командами и не позволит использовать системные сочетания Windows."/></Grid><TextBlock Text="Диктовка" Classes="muted" FontSize="11"/><TextBox x:Name="DictationHotkeyBox" IsReadOnly="True" KeyDown="CaptureHotkey" Tag="dictation"/><TextBlock Text="Отмена исправления" Classes="muted" FontSize="11"/><TextBox x:Name="UndoHotkeyBox" IsReadOnly="True" KeyDown="CaptureHotkey" Tag="undo"/><Border x:Name="HotkeyValidationBorder" Classes="setting"><TextBlock x:Name="HotkeyValidationText" Text="Сочетания свободны" Foreground="#52E58A" FontSize="11" TextWrapping="Wrap"/></Border><TextBlock Text="Нажмите на поле, затем нажмите нужное сочетание." Classes="muted" FontSize="10"/></StackPanel></Border>
     </Grid>
     <Border Classes="card"><StackPanel Spacing="12"><Grid ColumnDefinitions="*,Auto"><StackPanel><TextBlock Text="Исключённые приложения" FontSize="17" FontWeight="Bold"/><TextBlock Text="В этих процессах автокоррекция и анализ клавиатуры отключены" Classes="muted" FontSize="11"/></StackPanel><Button Grid.Column="1" Classes="info" Content="i" ToolTip.Tip="Указывайте имя процесса без .exe, по одному на строку. Поля паролей в обычных Windows-приложениях защищаются автоматически."/></Grid><TextBox x:Name="ExcludedProcessesText" AcceptsReturn="True" MinHeight="120" FontFamily="Cascadia Mono, Consolas" LostFocus="ExcludedProcessesChanged"/></StackPanel></Border>
    </StackPanel>

    <StackPanel x:Name="AboutPanel" IsVisible="False" Spacing="20">
     <TextBlock Text="FOTUR / PRODUCT" Classes="eyebrow"/><TextBlock Text="Fotur Typing Helper" Classes="h1"/><TextBlock Text="Версия 0.2.0 · MIT · Windows x64" Classes="muted"/>
     <Grid ColumnDefinitions="1.2*,*" ColumnSpacing="16"><Border Classes="card"><StackPanel Spacing="14"><TextBlock Text="Незаметный слой между вами и клавиатурой" FontSize="20" FontWeight="Bold"/><TextBlock TextWrapping="Wrap" Text="Автокоррекция и распознавание речи работают локально. Содержимое ввода не сохраняется, аудио удаляется сразу после распознавания, а сетевой доступ нужен только для первой загрузки модели."/><Border Classes="setting"><TextBlock Text="Open source · приватность по умолчанию · подготовлено к будущей macOS-версии" Foreground="#62FFF7" TextWrapping="Wrap"/></Border></StackPanel></Border><Border Grid.Column="1" Classes="card"><StackPanel Spacing="12"><TextBlock Text="Диагностика" FontSize="17" FontWeight="Bold"/><TextBlock Text="Если диктовка не запускается, подробности записываются в локальный журнал без вашего текста." Classes="muted" TextWrapping="Wrap"/><TextBlock Text="%LOCALAPPDATA%\Fotur\TypingHelper\logs" FontFamily="Cascadia Mono, Consolas" FontSize="11" Foreground="#A9BBB9"/></StackPanel></Border></Grid>
    </StackPanel>
   </Grid></ScrollViewer>
  </Grid>
 </Grid>
</Window>
